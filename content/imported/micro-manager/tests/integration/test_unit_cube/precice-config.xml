<?xml version="1.0" encoding="UTF-8" ?>
<precice-configuration experimental="true">
  <log>
    <sink type="stream" output="stdout" filter="%Severity% > debug" enabled="true" />
  </log>

  <data:scalar name="Micro-1" />
  <data:vector name="Micro-2" />
  <data:scalar name="Macro-1" />
  <data:scalar name="Active-State" />
  <data:scalar name="Active-Steps" />
  <data:scalar name="Rank" />

  <mesh name="Macro-Cube-Mesh" dimensions="3">
    <use-data name="Micro-1" />
    <use-data name="Micro-2" />
    <use-data name="Macro-1" />
    <use-data name="Active-State" />
    <use-data name="Active-Steps" />
    <use-data name="Rank" />
  </mesh>

  <participant name="Macro-Cube">
    <provide-mesh name="Macro-Cube-Mesh" />
    <read-data name="Micro-1" mesh="Macro-Cube-Mesh" />
    <read-data name="Micro-2" mesh="Macro-Cube-Mesh" />
    <write-data name="Macro-1" mesh="Macro-Cube-Mesh" />
  </participant>

  <participant name="Micro-Manager">
    <receive-mesh name="Macro-Cube-Mesh" from="Macro-Cube" direct-access="true" />
    <read-data name="Macro-1" mesh="Macro-Cube-Mesh" />
    <write-data name="Micro-1" mesh="Macro-Cube-Mesh" />
    <write-data name="Micro-2" mesh="Macro-Cube-Mesh" />
    <write-data name="Active-State" mesh="Macro-Cube-Mesh" />
    <write-data name="Active-Steps" mesh="Macro-Cube-Mesh" />
    <write-data name="Rank" mesh="Macro-Cube-Mesh" />
    <export:vtu directory="output" />
  </participant>

  <m2n:sockets acceptor="Micro-Manager" connector="Macro-Cube" />

  <coupling-scheme:serial-explicit>
    <participants first="Micro-Manager" second="Macro-Cube" />
    <max-time value="3" />
    <time-window-size value="1" />
    <exchange data="Micro-1" mesh="Macro-Cube-Mesh" from="Micro-Manager" to="Macro-Cube" />
    <exchange data="Micro-2" mesh="Macro-Cube-Mesh" from="Micro-Manager" to="Macro-Cube" />
    <exchange data="Macro-1" mesh="Macro-Cube-Mesh" from="Macro-Cube" to="Micro-Manager" />
  </coupling-scheme:serial-explicit>
</precice-configuration>
